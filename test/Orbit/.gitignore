# Obsidian workspace state — regenerated on open, not worth committing
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/appearance.json
.obsidian/graph.json
.obsidian/core-plugins.json
.obsidian/hotkeys.json
.obsidian/types.json
.obsidian/cache
.trash/

# Plugin under development — copied in from the build output by esbuild
# (main.js, dev-stamped manifest.json, styles.css) plus the Hot Reload marker
# and any runtime state. All generated; never committed.
.obsidian/plugins/*/data.json
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/plugins/*/manifest.json
.obsidian/plugins/*/.hotreload

# Keep hot-reload (committed tooling)
!.obsidian/plugins/hot-reload/main.js
!.obsidian/plugins/hot-reload/manifest.json
