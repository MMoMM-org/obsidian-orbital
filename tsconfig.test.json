{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["vitest/globals", "node"]
	},
	"include": [
		"src/**/*.ts",
		"test/**/*.ts"
	]
}
